<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="KLALIK.Views.ClientDashboard">
  <DockPanel>
    <Border DockPanel.Dock="Top"
            Padding="12,10"
            Background="{DynamicResource BrushBgToolbar}">
      <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
        <TextBlock x:Name="BalanceText"
                   VerticalAlignment="Center"
                   Foreground="{DynamicResource BrushTextPrimary}"
                   FontSize="14" />
        <Button x:Name="TopUpButton"
                Grid.Column="1"
                Content="Пополнить"
                MinWidth="120" />
        <Button x:Name="RefreshButton"
                Grid.Column="2"
                Content="Обновить"
                MinWidth="100" />
      </Grid>
    </Border>

    <Grid ColumnDefinitions="220,*" Margin="0,0,12,12">
      <!-- Левая колонка: логотип сверху, навигация снизу -->
      <Grid RowDefinitions="Auto,*,Auto"
            RowSpacing="0">
        <Border x:Name="BrandLogoHost"
                Margin="12,12,12,0"
                Padding="10"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Top"
                Background="White"
                CornerRadius="10"
                Cursor="Hand"
                ToolTip.Tip="Услуги">
          <Viewbox Stretch="Uniform"
                   HorizontalAlignment="Stretch"
                   VerticalAlignment="Center">
            <Image x:Name="BrandLogo"
                   Width="128"
                   Height="128"
                   Stretch="Uniform" />
          </Viewbox>
        </Border>

        <StackPanel Grid.Row="2"
                    VerticalAlignment="Bottom"
                    Spacing="8"
                    Margin="12,0,12,0">
          <Button x:Name="LogoutButton"
                  Content="Выйти"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Center" />
          <Button x:Name="NavBookingsButton"
                  Content="Мои записи"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Center" />
          <Button x:Name="NavReviewButton"
                  Content="Отзыв"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Center" />
          <Button x:Name="NavMyReviewsButton"
                  Content="Мои отзывы"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Center" />
        </StackPanel>
      </Grid>

      <!-- Правая область: каталог или экраны записей/отзывов -->
      <Grid Grid.Column="1"
            Margin="12,12,0,0">
        <!-- Каталог: вкладки + поиск/фильтр справа, товары снизу -->
        <Grid x:Name="CatalogPanel"
              RowDefinitions="Auto,*"
              RowSpacing="10">
          <Grid ColumnDefinitions="Auto,Auto,*,200,200"
                ColumnSpacing="10">
            <ToggleButton x:Name="CatalogTabCustom"
                          Content="Кастом"
                          MinWidth="120"
                          Padding="14,8" />
            <ToggleButton x:Name="CatalogTabCustomization"
                          Grid.Column="1"
                          Content="Кастомизация"
                          MinWidth="140"
                          Padding="14,8" />
            <Grid Grid.Column="3">
              <TextBox x:Name="CosplaySearchBox"
                       PlaceholderText="Поиск по названию или описанию…" />
              <TextBox x:Name="CustomSearchBox"
                       PlaceholderText="Поиск по названию или описанию…"
                       IsVisible="False" />
            </Grid>
            <Grid Grid.Column="4">
              <ComboBox x:Name="CosplayDirectionFilter"
                        PlaceholderText="Фильтр: коллекция" />
              <ComboBox x:Name="CustomDirectionFilter"
                        PlaceholderText="Фильтр: коллекция"
                        IsVisible="False" />
            </Grid>
          </Grid>
          <ScrollViewer x:Name="CosplayServicesScroll"
                        Grid.Row="1">
            <StackPanel x:Name="CosplayServicesPanel" Spacing="12" />
          </ScrollViewer>
          <ScrollViewer x:Name="CustomServicesScroll"
                        Grid.Row="1"
                        IsVisible="False">
            <StackPanel x:Name="CustomServicesPanel" Spacing="12" />
          </ScrollViewer>
        </Grid>

        <Grid x:Name="BookingsPanel"
              IsVisible="False">
          <ListBox x:Name="BookingsList" />
        </Grid>

        <ScrollViewer x:Name="ReviewPanel"
                      IsVisible="False">
          <StackPanel Margin="0,0,0,12"
                      Spacing="10"
                      MaxWidth="520"
                      HorizontalAlignment="Left">
            <TextBlock Text="Тип отзыва"
                       Foreground="{DynamicResource BrushTextSecondary}" />
            <ComboBox x:Name="ReviewTargetType"
                      PlaceholderText="Услуга или мастер">
              <ComboBoxItem Content="Услуга" Tag="service" />
              <ComboBoxItem Content="Мастер" Tag="master" />
            </ComboBox>
            <ComboBox x:Name="ReviewTargetPicker"
                      PlaceholderText="Выберите объект" />
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="Оценка (1–5)"
                         VerticalAlignment="Center"
                         Foreground="{DynamicResource BrushTextSecondary}" />
              <NumericUpDown x:Name="ReviewRating"
                             Minimum="1"
                             Maximum="5"
                             Value="5"
                             Width="120" />
            </StackPanel>
            <TextBox x:Name="ReviewComment"
                     PlaceholderText="Текст отзыва"
                     AcceptsReturn="True"
                     Height="100" />
            <Button x:Name="SubmitReviewButton"
                    Content="Отправить отзыв"
                    HorizontalAlignment="Left"
                    MinWidth="160" />
          </StackPanel>
        </ScrollViewer>

        <ScrollViewer x:Name="MyReviewsPanelHost"
                      IsVisible="False">
          <StackPanel x:Name="MyReviewsPanel" Spacing="12" />
        </ScrollViewer>
      </Grid>
    </Grid>
  </DockPanel>
</UserControl>
